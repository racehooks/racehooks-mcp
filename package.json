{
  "name": "@racehooks/mcp",
  "version": "0.3.1",
  "description": "MCP server for RaceHooks — motorsport analytics and data delivery for Claude, Cursor, and Windsurf",
  "mcpName": "io.github.racehooks/racehooks-mcp",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/racehooks/racehooks-mcp.git"
  },
  "homepage": "https://racehooks.io",
  "bugs": {
    "url": "https://github.com/racehooks/racehooks-mcp/issues"
  },
  "bin": {
    "racehooks-mcp": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "sync-version": "node scripts/sync-version.mjs",
    "release": "semantic-release"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "f1",
    "formula1",
    "formula-1",
    "webhook",
    "claude",
    "cursor",
    "windsurf",
    "ai",
    "live-timing",
    "motorsport",
    "f1-api",
    "race-data"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.3",
    "racehooks": "^0.4.0"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "semantic-release": "^25.0.7",
    "ts-jest": "^29.4.11",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": {
            "module": "NodeNext",
            "moduleResolution": "NodeNext"
          }
        }
      ]
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
